# ============================================================
#  Virex Security — .gitignore
# ============================================================

# ⚠️ Secrets — لا ترفعهم أبداً
.env
.env.local
.env.production
env

# ⚠️ User Data — بيانات حساسة لا ترفعها
users.json
users.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ML Model Files (كبيرة الحجم — استخدم Git LFS لو محتاج)
model.pkl
vectorizer.pkl

# Logs & Data
siem_audit.json
*.log

# Generated artifacts
ml_evaluation_report.png

# Virtual environments
.venv/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
