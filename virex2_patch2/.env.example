# ============================================================
#  Virex Security System - Environment Variables
# ============================================================

# Dashboard URL
DASHBOARD_URL=http://127.0.0.1:8070

# CORS origins (comma-separated, no wildcard)
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# JWT Secret Key — CHANGE THIS!
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ML Thresholds
ML_THRESHOLD_BLOCK=0.90
ML_THRESHOLD_MONITOR=0.70

# Max request body size (bytes) — 1MB default
MAX_CONTENT_LENGTH=1048576

# Flask
FLASK_ENV=production
FLASK_DEBUG=0
