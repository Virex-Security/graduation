# ============================================================
#  Virex Security System — Environment Template
# ============================================================
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to Git.
#
#  Generate secure secrets with:
#    python -c "import secrets; print(secrets.token_hex(64))"
#    python -c "import secrets; print(secrets.token_urlsafe(48))"
# ============================================================

# ── Required Secrets ─────────────────────────────────────────
# JWT signing key — minimum 64 hex chars (128-bit entropy)
SECRET_KEY=REPLACE_WITH_secrets.token_hex(64)

# Internal API communication token — minimum 32 chars
INTERNAL_API_SECRET=REPLACE_WITH_secrets.token_urlsafe(48)

# ── Server URLs ──────────────────────────────────────────────
DASHBOARD_URL=http://127.0.0.1:8070
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ── Cookie Security ──────────────────────────────────────────
# Set "true" for production (HTTPS only), "false" for local dev
COOKIE_SECURE=true

# ── SMTP (password reset emails) ─────────────────────────────
# Use a Gmail App Password, not your real password
SMTP_EMAIL=
SMTP_PASSWORD=

# ── Flask Runtime ────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0

# Comma-separated list of trusted proxy IPs (e.g. Nginx, Cloudflare, ALB)
# IPs in this list are ignored when detecting the real client IP from X-Forwarded-For.
TRUSTED_PROXIES=127.0.0.1
MAX_CONTENT_LENGTH=1048576

# ── ML Thresholds ────────────────────────────────────────────
ML_THRESHOLD_BLOCK=0.90
ML_THRESHOLD_MONITOR=0.70
